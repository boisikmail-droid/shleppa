{
    "name": "hat/game-backend",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.2",
        "nelmio/cors-bundle": "^2.5",
        "symfony/console": "^7.1",
        "symfony/dotenv": "^7.1",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "^7.1",
        "symfony/property-access": "^7.1",
        "symfony/runtime": "^7.1",
        "symfony/routing": "^7.1",
        "symfony/serializer": "^7.1",
        "symfony/validator": "^7.1",
        "symfony/yaml": "^7.1"
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.60"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [],
        "post-update-cmd": []
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.1.*"
        }
    }
}
